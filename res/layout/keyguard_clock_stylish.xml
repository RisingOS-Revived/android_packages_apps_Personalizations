<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foregroundGravity="center">

    <LinearLayout
        android:id="@+id/overlap_layer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextClock
            android:id="@+id/text_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/BR_SC"
            android:textColor="@android:color/white"
            android:textSize="100sp"
            android:layout_gravity="center"
            android:format12Hour="dd" />

        <TextClock
            android:id="@+id/text_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/FontsFree-Net-Carthart"
            android:textSize="60sp"
            android:textColor="#FFFD1540"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:format12Hour="EEE" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center">

            <TextClock
                android:id="@+id/text_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/Sans_Bold"
                android:textSize="24sp"
                android:textAllCaps="true"
                android:layout_gravity="center"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:format12Hour="hh:mm a" />

            <View
                android:id="@+id/bottom_bar"
                android:layout_width="140dp"
                android:layout_height="6dp"
                android:layout_gravity="center"
                android:background="#FFFD1540"
                android:layout_marginTop="10dp" />

            <LinearLayout
		    android:layout_width="wrap_content"
		    android:layout_height="wrap_content"
		    android:layout_gravity="center"
		    android:layout_marginTop="10dp"
		    android:orientation="horizontal">

		    <com.rising.settings.fragments.lockscreen.DummyWeatherImageView
			    android:id="@+id/weather_image"
			    android:layout_width="20dp"
			    android:layout_height="20dp"
			    android:layout_marginEnd="4dp"
		            android:adjustViewBounds="true" />
			    
		    <com.rising.settings.fragments.lockscreen.DummyWeatherTextView
			    android:id="@+id/weather_text"
			    android:layout_width="wrap_content"
			    android:layout_height="wrap_content"
			    android:layout_marginStart="4dp"
			    android:layout_marginEnd="8dp"
			    android:fontFamily="@font/Sans_Bold"
			    android:textColor="@android:color/white"
			    android:textSize="20sp" />            
		</LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
